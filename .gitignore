# Root Gitignore for the Quiz Platform Repository

# Dependecy directories
node_modules/
frontend/node_modules/
backend/node_modules/

# Production builds
dist/
frontend/dist/
frontend/dist-ssr/

# Environment files and secrets
.env
.env.local
.env.*.local
frontend/.env*
backend/.env*

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# System & OS Files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs and Editor configurations
.vscode/
.idea/
*.suo
*.ntvsca
*.njsproj
*.sln
*.sw?
